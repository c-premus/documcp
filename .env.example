# =============================================================================
# DocuMCP-Go Configuration
# Copy to .env and customize for your environment.
# All values shown are defaults — only set what you need to override.
# =============================================================================

# --- Application ---
APP_NAME=DocuMCP
APP_ENV=development                        # development | staging | production | testing
APP_DEBUG=false
APP_URL=http://localhost
APP_TIMEZONE=UTC
# Required in production. Generate: openssl rand -hex 32
INTERNAL_API_TOKEN=
# 64-char hex string (32 bytes decoded), required in production (AES-256-GCM)
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# --- Server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s
SERVER_IDLE_TIMEOUT=120s
SERVER_READ_HEADER_TIMEOUT=5s
SERVER_SHUTDOWN_TIMEOUT=5s
SERVER_REQUEST_TIMEOUT=60s
SERVER_MAX_BODY_SIZE=1048576               # 1 MB (bytes)
SERVER_HSTS_MAX_AGE=63072000               # 2 years (seconds), 0 to disable
SERVER_SSE_HEARTBEAT_INTERVAL=15s

# --- Database (PostgreSQL) ---
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=documcp
DB_USERNAME=documcp
DB_PASSWORD=                               # Required in production
DB_SSLMODE=require
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_MAX_LIFETIME=5m

# --- Database (pgx pool for River queue) ---
DB_PGX_MIN_CONNS=2
DB_PGX_MAX_CONN_LIFETIME=30m
DB_PGX_MAX_CONN_IDLE_TIME=5m

# --- Redis (distributed rate limiting + event delivery) ---
REDIS_ADDR=localhost:6379
REDIS_USERNAME=                              # Redis 6+ ACL username (empty = default user)
REDIS_PASSWORD=
REDIS_DB=0

# --- OIDC Authentication ---
OIDC_PROVIDER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=
OIDC_SCOPES=openid,profile,email
OIDC_ADMIN_GROUPS=                         # Comma-separated group names for admin sync
# Manual endpoints (skip auto-discovery):
OIDC_AUTHORIZATION_URL=
OIDC_TOKEN_URL=
OIDC_USERINFO_URL=
OIDC_JWKS_URL=

# --- OAuth 2.1 Server ---
OAUTH_SESSION_SECRET=                      # Min 32 chars, required in production. Generate: openssl rand -base64 32
OAUTH_SESSION_SECRET_PREVIOUS=             # For key rotation
OAUTH_SESSION_MAX_AGE=720h                 # 30 days
HKDF_SALT=DocuMCP-go-v1                   # Per-deployment salt — MUST change from default in production
OAUTH_AUTHORIZATION_CODE_LIFETIME=10m
OAUTH_ACCESS_TOKEN_LIFETIME=1h
OAUTH_REFRESH_TOKEN_LIFETIME=720h
OAUTH_DEVICE_CODE_LIFETIME=10m
OAUTH_DEVICE_POLLING_INTERVAL=5s
OAUTH_REGISTRATION_ENABLED=true
# When false, unauthenticated registration is allowed but constrained:
# public clients only, read-only scopes, no device_code grant.
# Rate-limited to 10/hr + 50/day per IP. Safe for mcp-remote.
OAUTH_REGISTRATION_REQUIRE_AUTH=true
OAUTH_CLIENT_TOUCH_TIMEOUT=3s

# --- Storage ---
STORAGE_DRIVER=local
STORAGE_BASE_PATH=./storage
STORAGE_DOCUMENT_PATH=documents
STORAGE_TEMP_PATH=tmp

# --- External Services: Kiwix ---
KIWIX_CACHE_TTL=1h
KIWIX_HTTP_TIMEOUT=10s
KIWIX_HEALTH_CHECK_TIMEOUT=5s
KIWIX_FEDERATED_SEARCH_TIMEOUT=3s       # Deadline for Kiwix fan-out during unified_search
KIWIX_FEDERATED_MAX_ARCHIVES=10          # Max archives to search in parallel
KIWIX_FEDERATED_PER_ARCHIVE_LIMIT=3      # Max results per archive

# --- External Services: Git Templates ---
GIT_MAX_FILE_SIZE=1048576                  # 1 MB per file (bytes)
GIT_MAX_TOTAL_SIZE=10485760                # 10 MB total (bytes)

# --- Security ---
SSRF_DIALER_TIMEOUT=10s

# --- Queue Workers ---
QUEUE_HIGH_WORKERS=10                      # River high-priority queue concurrency
QUEUE_DEFAULT_WORKERS=5                    # River default queue concurrency
QUEUE_LOW_WORKERS=2                        # River low-priority queue concurrency
WORKER_HEALTH_PORT=9090                    # Health endpoint port (worker-only mode)

# --- Lifecycle ---
APP_QUEUE_STOP_TIMEOUT=10s
APP_TRACER_STOP_TIMEOUT=5s

# --- OpenTelemetry ---
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=documcp
OTEL_INSECURE=false

# --- MCP Server ---
DOCUMCP_ENDPOINT=/documcp
DOCUMCP_NAME=DocuMCP
DOCUMCP_VERSION=0.1.0

# --- Scheduler (cron expressions, empty to disable) ---
SCHEDULER_ENABLED=false
SCHEDULER_KIWIX_SCHEDULE=0 */6 * * *
SCHEDULER_GIT_SCHEDULE=0 * * * *
SCHEDULER_OAUTH_CLEANUP_SCHEDULE=0 * * * *
SCHEDULER_ORPHANED_FILES_SCHEDULE=0 2 * * *
SCHEDULER_SOFT_DELETE_PURGE_SCHEDULE=0 4 * * *
SCHEDULER_HEALTH_CHECK_SCHEDULE=*/15 * * * *
