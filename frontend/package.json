{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "vue-tsc --noEmit && eslint .",
    "lint:fix": "eslint . --fix && prettier --write src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/"
  },
  "dependencies": {
    "@headlessui/vue": "1.7.23",
    "@heroicons/vue": "2.2.0",
    "@sentry/vue": "10.51.0",
    "@tanstack/vue-table": "8.21.3",
    "date-fns": "4.1.0",
    "dompurify": "3.4.2",
    "marked": "18.0.2",
    "mermaid": "11.14.0",
    "pinia": "3.0.4",
    "vue": "3.5.33",
    "vue-router": "5.0.6",
    "vue-sonner": "2.0.9"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tailwindcss/forms": "0.5.11",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.2.4",
    "@types/node": "25.6.0",
    "@vitejs/plugin-vue": "6.0.6",
    "@vitest/coverage-v8": "4.1.5",
    "@vue/eslint-config-prettier": "10.2.0",
    "@vue/test-utils": "2.4.10",
    "@vue/tsconfig": "0.9.1",
    "autoprefixer": "10.5.0",
    "eslint": "10.2.1",
    "eslint-plugin-vue": "10.9.0",
    "globals": "17.5.0",
    "jsdom": "29.1.1",
    "postcss": "8.5.13",
    "prettier": "3.8.3",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.1",
    "vite": "8.0.10",
    "vitest": "4.1.5",
    "vue-tsc": "3.2.7"
  },
  "overrides": {
    "dompurify": "3.4.2",
    "uuid": "^14.0.0"
  }
}
