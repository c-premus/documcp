{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "vue-tsc --noEmit && eslint .",
    "lint:fix": "eslint . --fix && prettier --write src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/"
  },
  "dependencies": {
    "@headlessui/vue": "1.7.23",
    "@heroicons/vue": "2.2.0",
    "@sentry/vue": "10.64.0",
    "@tanstack/vue-table": "8.21.3",
    "date-fns": "4.4.0",
    "dompurify": "3.4.11",
    "marked": "18.0.5",
    "mermaid": "^11.15.0",
    "pinia": "3.0.4",
    "vue": "3.5.39",
    "vue-router": "5.1.0",
    "vue-sonner": "2.0.9"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tailwindcss/forms": "0.5.11",
    "@tailwindcss/typography": "0.5.20",
    "@tailwindcss/vite": "4.3.2",
    "@types/node": "25.9.5",
    "@vitejs/plugin-vue": "6.0.7",
    "@vitest/coverage-v8": "4.1.10",
    "@vue/eslint-config-prettier": "10.2.0",
    "@vue/test-utils": "2.4.11",
    "@vue/tsconfig": "0.9.1",
    "autoprefixer": "10.5.2",
    "eslint": "10.6.0",
    "eslint-plugin-vue": "10.9.2",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "postcss": "8.5.16",
    "prettier": "3.9.4",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.3",
    "vitest": "4.1.10",
    "vue-tsc": "3.3.7"
  },
  "overrides": {
    "dompurify": "3.4.11"
  }
}
