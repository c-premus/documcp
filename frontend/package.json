{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "openapi-ts && vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "vue-tsc --noEmit && eslint .",
    "lint:fix": "eslint . --fix && prettier --write src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "generate-api": "openapi-ts"
  },
  "dependencies": {
    "@headlessui/vue": "^1.7.23",
    "@heroicons/vue": "^2.2.0",
    "@scalar/api-reference": "^1.52.1",
    "@sentry/vue": "^10.48.0",
    "@tanstack/vue-table": "^8.21.3",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.3",
    "marked": "^18.0.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4",
    "vue-sonner": "^2.0.9"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@hey-api/openapi-ts": "0.96.0",
    "@tailwindcss/forms": "0.5.11",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.2.2",
    "@types/node": "25.6.0",
    "@vitejs/plugin-vue": "6.0.6",
    "@vitest/coverage-v8": "4.1.4",
    "@vue/eslint-config-prettier": "10.2.0",
    "@vue/test-utils": "2.4.6",
    "@vue/tsconfig": "0.9.1",
    "autoprefixer": "10.4.27",
    "eslint": "10.2.0",
    "eslint-plugin-vue": "10.8.0",
    "globals": "17.5.0",
    "jsdom": "29.0.2",
    "postcss": "8.5.9",
    "prettier": "3.8.2",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.1",
    "vite": "8.0.8",
    "vitest": "4.1.4",
    "vue-tsc": "3.2.6"
  },
  "overrides": {
    "dompurify": "^3.3.3"
  }
}
